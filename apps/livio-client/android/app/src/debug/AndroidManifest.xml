<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- The INTERNET permission is required for development. Specifically,
         the Flutter tool needs it to communicate with the running application
         to allow setting breakpoints, to provide hot reload, etc.
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Android 9+ bloquea el tráfico HTTP sin cifrar por defecto, y el backend
         de desarrollo corre en http://10.0.2.2:8000 (Kong, todavía sin TLS).

         La excepción vive SOLO en el manifiesto de debug: Gradle no la aplica a
         las builds de release, así que no puede colarse en una versión
         publicada. Y en vez de abrir el HTTP a cualquier destino, el config
         referenciado lista únicamente las direcciones de desarrollo.

         Cuando el backend tenga TLS y dominio, esto se elimina entero. -->
    <application android:networkSecurityConfig="@xml/network_security_config" />
</manifest>
