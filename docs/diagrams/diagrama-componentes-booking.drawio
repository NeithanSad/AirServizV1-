        <mxCell id="metrics" parent="1" style="rounded=1;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="&lt;b&gt;MetricsModule&lt;/b&gt; · GET /metrics" vertex="1">
