<mxfile host="app.diagrams.net">
  <diagram id="componentes-booking" name="Componentes booking-service">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1320" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="AirServiz — Diagrama de componentes: booking-service (C4 · nivel 3)" vertex="1">
          <mxGeometry height="30" width="900" x="70" y="15" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#666666;" value="El núcleo del dominio: gestiona el ciclo de vida de una orden y es el ORIGEN de los eventos del sistema · flecha sólida = llamada, discontinua = evento / telemetría" vertex="1">
          <mxGeometry height="20" width="1200" x="70" y="45" as="geometry" />
        </mxCell>

        <mxCell id="kong" parent="1" style="rounded=1;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="&lt;b&gt;API Gateway — Kong&lt;/b&gt; :8000&lt;br&gt;valida el JWT antes de llegar aquí" vertex="1">
          <mxGeometry height="50" width="330" x="240" y="90" as="geometry" />
        </mxCell>

        <mxCell id="boundary" parent="1" style="rounded=0;html=1;dashed=1;fillColor=none;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=12;fontStyle=1;fontColor=#333333;" value="booking-service — NestJS 10 · Node 20 · :3002 (contenedor Docker)" vertex="1">
          <mxGeometry height="470" width="770" x="70" y="175" as="geometry" />
        </mxCell>

        <mxCell id="controller" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="&lt;b&gt;OrdersController&lt;/b&gt; [REST]&lt;br&gt;POST /orders · GET /orders&lt;br&gt;GET /orders/:id&lt;br&gt;PATCH /orders/:id/status" vertex="1">
          <mxGeometry height="80" width="330" x="240" y="210" as="geometry" />
        </mxCell>
        <mxCell id="service" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="&lt;b&gt;OrdersService&lt;/b&gt; [lógica de negocio]&lt;br&gt;calcula el total · valida transiciones&lt;br&gt;verifica quién puede hacer cada cambio&lt;br&gt;&lt;i&gt;el corazón del servicio&lt;/i&gt;" vertex="1">
          <mxGeometry height="100" width="330" x="240" y="335" as="geometry" />
        </mxCell>

        <mxCell id="repo" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="&lt;b&gt;Repository&amp;lt;OrderEntity&amp;gt;&lt;/b&gt;&lt;br&gt;TypeORM · migraciones al arrancar" vertex="1">
          <mxGeometry height="60" width="230" x="95" y="470" as="geometry" />
        </mxCell>
        <mxCell id="producer" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" value="&lt;b&gt;KafkaProducerService&lt;/b&gt;&lt;br&gt;emite 4 eventos (gzip · key = orderId)" vertex="1">
