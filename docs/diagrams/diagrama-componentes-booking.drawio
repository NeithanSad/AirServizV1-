        <mxCell id="footer" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=2;fontColor=#666666;" value="Cubierto por orders.service.spec.ts (17 tests): transiciones válidas e inválidas, permisos de cada rol, flujo de reprogramación completo y emisión de eventos." vertex="1">
