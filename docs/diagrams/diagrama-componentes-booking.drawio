        <mxCell id="pg" parent="1" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=12;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" value="PostgreSQL&#xa;bookings_db :5434&#xa;tabla orders" vertex="1">
          <mxGeometry height="75" width="230" x="95" y="690" as="geometry" />
        </mxCell>
