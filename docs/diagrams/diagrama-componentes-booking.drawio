        <mxCell id="sm_note" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=9;fontColor=#666666;" value="Cualquier estado no terminal → CANCELADA (cliente o proveedor).&lt;br&gt;Toda otra transición se rechaza con 400. COMPLETADA y CANCELADA son finales." vertex="1">
