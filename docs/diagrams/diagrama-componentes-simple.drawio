          <mxGeometry height="55" width="220" x="475" y="450" as="geometry" />
        </mxCell>
        <mxCell id="producer" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;KafkaProducer&lt;/b&gt;&lt;br&gt;emite eventos" vertex="1">
          <mxGeometry height="55" width="220" x="840" y="450" as="geometry" />
        </mxCell>

        <mxCell id="adapter" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;StripeSimulatedGateway&lt;/b&gt;&lt;br&gt;adaptador · firma HMAC real" vertex="1">
          <mxGeometry height="60" width="220" x="475" y="550" as="geometry" />
        </mxCell>

        <mxCell id="pg" parent="1" style="shape=cylinder3;boundedLbl=1;backgroundOutline=1;size=12;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" value="PostgreSQL&#xa;payments_db" vertex="1">
          <mxGeometry height="75" width="220" x="110" y="680" as="geometry" />
        </mxCell>
        <mxCell id="kafka_out" parent="1" style="rounded=1;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Kafka&lt;/b&gt; — sale el evento&lt;br&gt;payment_processed → notification" vertex="1">
          <mxGeometry height="60" width="220" x="840" y="680" as="geometry" />
        </mxCell>

        <mxCell id="note" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#333333;" value="&lt;b&gt;Pasos 1–4 (asíncrono):&lt;/b&gt; se confirma la orden → se crea el cobro pendiente. &amp;nbsp;&amp;nbsp; &lt;b&gt;Pasos 5–9 (síncrono):&lt;/b&gt; el cliente paga → se cobra y se avisa." vertex="1">
          <mxGeometry height="20" width="1000" x="80" y="785" as="geometry" />
        </mxCell>
        <mxCell id="note2" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontStyle=2;fontColor=#666666;" value="Las dos cajas de Kafka son el mismo bus, dibujado dos veces (entrada y salida) para seguir el flujo." vertex="1">
          <mxGeometry height="20" width="1000" x="80" y="810" as="geometry" />
        </mxCell>

