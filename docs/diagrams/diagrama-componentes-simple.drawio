<mxfile host="app.diagrams.net">
  <diagram id="componentes-simple" name="Componentes (simplificado)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1150" pageHeight="860" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=18;fontStyle=1;" value="payment-service — ciclo de vida de un cobro" vertex="1">
          <mxGeometry height="30" width="800" x="60" y="15" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" parent="1" style="text;html=1;align=left;verticalAlign=top;fontSize=11;fontColor=#666666;" value="Sigue los números del 1 al 9 · dos entradas (evento y HTTP), un solo cerebro" vertex="1">
          <mxGeometry height="20" width="1000" x="60" y="45" as="geometry" />
        </mxCell>

        <mxCell id="kafka_in" parent="1" style="rounded=1;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" value="&lt;b&gt;Kafka&lt;/b&gt; — llega el evento&lt;br&gt;order_confirmed (de booking)" vertex="1">
          <mxGeometry height="55" width="260" x="130" y="85" as="geometry" />
        </mxCell>
        <mxCell id="kong" parent="1" style="rounded=1;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" value="&lt;b&gt;Kong&lt;/b&gt; :8000&lt;br&gt;el cliente pulsa pagar (JWT ya validado)" vertex="1">
          <mxGeometry height="55" width="260" x="790" y="85" as="geometry" />
        </mxCell>

        <mxCell id="boundary" parent="1" style="rounded=0;html=1;dashed=1;fillColor=none;strokeColor=#6c8ebf;verticalAlign=top;align=left;spacingLeft=8;spacingTop=4;fontSize=12;fontStyle=1;fontColor=#333333;" value="payment-service (NestJS :3006)" vertex="1">
          <mxGeometry height="455" width="990" x="80" y="175" as="geometry" />
        </mxCell>

        <mxCell id="consumer" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;PaymentsConsumer&lt;/b&gt;&lt;br&gt;puerta asíncrona (Kafka)" vertex="1">
          <mxGeometry height="60" width="260" x="130" y="210" as="geometry" />
        </mxCell>
        <mxCell id="controller" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;PaymentsController&lt;/b&gt;&lt;br&gt;puerta síncrona (REST)" vertex="1">
          <mxGeometry height="60" width="260" x="790" y="210" as="geometry" />
        </mxCell>

        <mxCell id="service" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;PaymentsService&lt;/b&gt; — el cerebro&lt;br&gt;toda la lógica de negocio&lt;br&gt;&lt;i&gt;evita cobros duplicados (idempotencia)&lt;/i&gt;" vertex="1">
          <mxGeometry height="75" width="330" x="420" y="330" as="geometry" />
        </mxCell>

        <mxCell id="repo" parent="1" style="rounded=1;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" value="&lt;b&gt;Repository&lt;/b&gt;&lt;br&gt;persistencia" vertex="1">
