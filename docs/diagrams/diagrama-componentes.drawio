        <mxCell id="obs" parent="1" style="rounded=1;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" value="&lt;b&gt;Observabilidad&lt;/b&gt;&lt;br&gt;Prometheus (scrape /metrics) · Logstash (logs TCP :5000)" vertex="1">
