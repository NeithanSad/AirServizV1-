# =============================================================================
# Secretos del entorno local — fuente única de verdad
#
# Copia este archivo a `.env` (mismo directorio). `.env` está en .gitignore y
# NUNCA se commitea; este `.env.example` sí, y por eso solo lleva marcadores.
#
# Arranque desde cero:
#
#     cp infra/docker-compose/.env.example infra/docker-compose/.env
#     bash scripts/rotate-secrets.sh      # genera valores reales y los propaga
#
# docker-compose lee este archivo automáticamente e interpola las variables.
# Todas usan la forma `${VAR:?mensaje}`: si falta una, Compose se NIEGA a
# levantar el stack en vez de arrancar con un valor por defecto inseguro.
# =============================================================================

# ── JWT ──────────────────────────────────────────────────────────────────────
# Secreto HS256 con el que auth-service FIRMA los tokens y con el que Kong los
# VALIDA. Es el mismo valor en ambos lados por construcción: auth-service lo
# recibe como variable de entorno, y kong-config-init lo inyecta en la config
# declarativa de Kong al arrancar (infra/kong/render-config.sh).
#
# Mínimo 32 bytes; el script genera 32 bytes en hex (64 caracteres).
# Genéralo con:  openssl rand -hex 32
JWT_SECRET=

# ── Pasarela de pago (simulada) ──────────────────────────────────────────────
# Clave HMAC con la que payment-service verifica la firma del webhook
# (esquema t=…,v1=…, comparación timing-safe, tolerancia 300s).
STRIPE_WEBHOOK_SECRET=

# ── PostgreSQL (una contraseña por base — database-per-service) ───────────────
# Contraseñas distintas a propósito: comprometer una base no da acceso a las
# otras tres.
#
# ⚠️ POSTGRES_PASSWORD solo surte efecto al inicializar un volumen VACÍO.
#    Cambiar estos valores con volúmenes ya creados NO cambia la contraseña
#    dentro de Postgres: solo rompe la conexión de los servicios.
#    Para rotarlas sin perder datos:  bash scripts/rotate-db-passwords.sh
POSTGRES_USERS_PASSWORD=
POSTGRES_BOOKINGS_PASSWORD=
POSTGRES_CATALOG_PASSWORD=
POSTGRES_PAYMENTS_PASSWORD=

# ── AWS — Lambda image-optimizer ─────────────────────────────────────────────
# Credenciales del usuario IAM dedicado `airserviz-catalog-invoker`, que SOLO
# tiene permiso lambda:InvokeFunction sobre airserviz-image-optimizer.
# Las consume catalog-service para la subida de imágenes de servicio.
#
# Genéralas una sola vez con:
#     aws iam create-access-key --user-name airserviz-catalog-invoker
#
# Si se dejan vacías, el catálogo funciona igual; solo POST /services/media
# devolvería 503.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
