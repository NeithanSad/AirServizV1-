# Copia este archivo a `.env` (mismo directorio) y rellena los valores.
# `.env` está en .gitignore — nunca se commitea.
#
# docker-compose interpola estas variables en el contenedor catalog-service
# para que pueda invocar la Lambda image-optimizer (subida de imagen de servicio).
#
# La access key es del usuario IAM dedicado `airserviz-catalog-invoker`,
# que SOLO tiene permiso lambda:InvokeFunction sobre airserviz-image-optimizer.
# Genérala en tu terminal (una sola vez):
#
#   aws iam create-access-key --user-name airserviz-catalog-invoker
#
# y pega abajo AccessKeyId y SecretAccessKey de la salida.

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
