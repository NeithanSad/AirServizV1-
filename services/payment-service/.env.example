# payment-service environment variables
# Copy to .env and fill in values for local development

PORT=3006

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_GROUP_ID=payment-service-group

# PostgreSQL
DB_HOST=postgres-payments
DB_PORT=5432
DB_NAME=payments_db
DB_USER=payments_admin
DB_PASS=change_me

# Stripe webhook signing secret (simulated gateway uses it to sign/verify)
STRIPE_WEBHOOK_SECRET=whsec_sim_dev_secret
