# payment-service environment variables
# Copy to .env and fill in values for local development

PORT=3006

# Kafka
KAFKA_BROKER=kafka:9092
KAFKA_GROUP_ID=payment-service-group

# PostgreSQL
DB_HOST=postgres-payments
DB_PORT=5432
DB_NAME=payments_db
DB_USER=payments_admin
DB_PASS=change_me

# Stripe webhook signing secret (simulated gateway uses it to sign/verify).
#
# ⚠️ Obligatorio y mínimo 32 caracteres: el gateway se NIEGA a arrancar sin él.
#    Antes caía a un valor por defecto que estaba commiteado, lo que permitía
#    forjar webhooks de pago si la variable faltaba.
#
# No lo pongas a mano: `bash scripts/rotate-secrets.sh` lo genera y lo escribe
# aquí y en infra/docker-compose/.env a la vez.
STRIPE_WEBHOOK_SECRET=replace_with_strong_secret_min_32_chars
