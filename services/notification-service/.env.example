# notification-service environment variables
# Copy to .env and fill in values for local development
#
# No tiene base de datos: el historial vive en memoria y se sirve por SSE.
# Tampoco valida JWT — de eso se encarga Kong en el borde.

PORT=3003

# Kafka — consume order_created / order_confirmed / order_cancelled /
# order_rescheduled / payment_processed
KAFKA_BROKER=kafka:9092
KAFKA_GROUP_ID=notification-service-group
KAFKAJS_NO_PARTITIONER_WARNING=1
