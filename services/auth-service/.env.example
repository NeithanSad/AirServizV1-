# auth-service environment variables
# Copy to .env and fill in values for local development
#
# Solo hace falta cuando auth-service corre en el HOST (`npm run start:dev`).
# En Docker, docker-compose inyecta estos valores desde
# infra/docker-compose/.env — no leas ni edites este archivo para el stack.

PORT=3001

# PostgreSQL (instancia compartida con user-service, tabla distinta)
DB_HOST=postgres-users
DB_PORT=5432
DB_NAME=users_db
DB_USER=users_admin
DB_PASS=change_me

# Auth
#
# ⚠️ Este secreto DEBE ser idéntico al `secret` del consumer JWT de Kong, o
#    Kong rechazará con 401 todo token que auth-service emita. No lo edites a
#    mano: `bash scripts/rotate-secrets.sh` genera uno nuevo y lo escribe a la
#    vez aquí y en infra/docker-compose/.env, que es de donde Kong lo toma.
#
# Mínimo 32 bytes.  Generar con:  openssl rand -hex 32
JWT_SECRET=replace_with_strong_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
