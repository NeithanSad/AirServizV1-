# booking-service environment variables
# Copy to .env and fill in values for local development

PORT=3002

# Kafka
KAFKA_BROKER=kafka:9092

# PostgreSQL (future – Sprint 2)
DB_HOST=postgres-bookings
DB_PORT=5432
DB_NAME=bookings_db
DB_USER=bookings_admin
DB_PASS=change_me

# Redis (future – Session / Cache)
REDIS_HOST=redis
REDIS_PORT=6379

# Auth
JWT_SECRET=replace_with_strong_secret
